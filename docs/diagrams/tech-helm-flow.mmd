flowchart LR
    subgraph CHART["📦 Helm Chart\n/infra/helm/greeting-service/"]
        direction TB
        TMPL["📄 templates/\ndeployment.yaml\nservice.yaml\ningress.yaml"]
        VALS["⚙️ values.yaml\nvalues-dev.yaml\nvalues-prod.yaml"]
    end

    subgraph HELM_CMD["🔧 helm upgrade --install"]
        direction TB
        RENDER["Template Engine\nподставляет values → YAML"]
    end

    subgraph K8S_API["☸️ Kubernetes API Server"]
        direction TB
        DEP["Deployment"]
        SVC["Service"]
        ING["Ingress"]
        SEC["Secret"]
    end

    subgraph RELEASE["📋 Helm Release History"]
        R1["revision 1"]
        R2["revision 2 ← текущий"]
        R3["revision 3 (при rollback)"]
    end

    TMPL --> RENDER
    VALS --> RENDER
    RENDER -->|"kubectl apply"| DEP
    RENDER -->|"kubectl apply"| SVC
    RENDER -->|"kubectl apply"| ING
    RENDER -->|"kubectl apply"| SEC
    HELM_CMD --> RELEASE
    R2 -->|"helm rollback"| R3

